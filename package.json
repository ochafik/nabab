{
  "name": "nabab",
  "version": "1.0.0",
  "description": "Bayesian Network inference engine with interactive visualization",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist/lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --project tsconfig.lib.json",
    "build:viewer": "vite build",
    "build:lib": "tsc --project tsconfig.lib.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "tsx src/mcp/server.ts"
  },
  "license": "MIT",
  "author": "Olivier Chafik",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@kanaries/causal": "^0.1.1",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "zod": "^4.3.6"
  }
}
